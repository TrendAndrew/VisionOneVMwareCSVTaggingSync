# =============================================================================
# VMware vSphere Connection (single vCenter)
# =============================================================================
# For a single vCenter, use these env vars.
# For multiple vCenters, define them in config JSON instead — see
# config/multi-vcenter.example.json and set CONFIG_PATH below.
VMWARE_HOST=vcenter.example.com
VMWARE_USERNAME=administrator@vsphere.local
VMWARE_PASSWORD=
VMWARE_VERIFY_SSL=true
# VMWARE_REQUEST_TIMEOUT_MS=30000

# =============================================================================
# Trend Vision One
# =============================================================================
VISIONONE_API_TOKEN=
# Region: us | eu | jp | sg | au | in | mea
VISIONONE_REGION=us
# VISIONONE_ENDPOINT_PAGE_SIZE=200
# VISIONONE_REQUEST_TIMEOUT_MS=30000
# VISIONONE_RATE_LIMIT_DELAY_MS=100

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=info
DRY_RUN=false
CONFIG_PATH=./config/default.json
